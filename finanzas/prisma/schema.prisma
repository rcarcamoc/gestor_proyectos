generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  country       String?
  mainCurrency  String    @default("USD")
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  households    UserHousehold[]
  accounts      Account[]
  categories    Category[]
  budgets       Budget[]
  savingsGoals  SavingsGoal[]
  telegramUser  TelegramUser?
  transactions  Transaction[] @relation("owner")
  createdTransactions Transaction[] @relation("creator")
}

model Household {
  id            String    @id @default(cuid())
  name          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         UserHousehold[]
  accounts      Account[]
  categories    Category[]
  budgets       Budget[]
  savingsGoals  SavingsGoal[]
  invitations   Invitation[]
  transactions  Transaction[]
}

model UserHousehold {
  id            String    @id @default(cuid())
  userId        String
  householdId   String
  role          String    @default("MEMBER") // ADMIN, MEMBER
  joinedAt      DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  household     Household @relation(fields: [householdId], references: [id])

  @@unique([userId, householdId])
}

model Invitation {
  id            String    @id @default(cuid())
  email         String
  householdId   String
  code          String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  status        String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED

  household     Household @relation(fields: [householdId], references: [id])
}

enum AccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  OTHER
}

model Account {
  id            String      @id @default(cuid())
  name          String
  type          AccountType @default(CHECKING)
  balance       Decimal     @default(0) @db.Decimal(15, 2)
  currency      String      @default("USD")
  isArchived    Boolean     @default(false)
  userId        String?
  householdId   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User?       @relation(fields: [userId], references: [id])
  household     Household?  @relation(fields: [householdId], references: [id])
  transactions  Transaction[]
}

model Category {
  id            String    @id @default(cuid())
  name          String
  icon          String?
  color         String?
  isDefault     Boolean   @default(false)
  userId        String?
  householdId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?       @relation(fields: [userId], references: [id])
  household     Household?  @relation(fields: [householdId], references: [id])
  transactions  Transaction[]
  budgets       Budget[]
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  MANUAL
  EXCEL
  EMAIL
  TELEGRAM
}

enum TransactionStatus {
  CONFIRMED
  PENDING_REVIEW
}

model Transaction {
  id              String            @id @default(cuid())
  amount          Decimal           @db.Decimal(15, 2)
  currency        String
  date            DateTime
  type            TransactionType
  description     String?
  source          TransactionSource @default(MANUAL)
  status          TransactionStatus @default(CONFIRMED)
  accountId       String
  categoryId      String?
  userId          String
  userId_internal String
  householdId     String?
  externalId      String?           // For deduplication (Message-ID, Excel row hash)
  metadata        Json?             // To store raw data from email/excel
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  account         Account           @relation(fields: [accountId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  household       Household?        @relation(fields: [householdId], references: [id])
  user            User              @relation(fields: [userId], references: [id], name: "owner")
  creator         User              @relation(fields: [userId_internal], references: [id], name: "creator")

  @@index([externalId])
}

model Budget {
  id            String    @id @default(cuid())
  limit         Decimal   @db.Decimal(15, 2)
  period        String    @default("MONTHLY")
  categoryId    String
  userId        String?
  householdId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category  @relation(fields: [categoryId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  household     Household? @relation(fields: [householdId], references: [id])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Decimal   @db.Decimal(15, 2)
  currentAmount Decimal   @default(0) @db.Decimal(15, 2)
  currency      String    @default("USD")
  deadline      DateTime?
  userId        String?
  householdId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?     @relation(fields: [userId], references: [id])
  household     Household? @relation(fields: [householdId], references: [id])
}

model ExcelProfile {
  id            String    @id @default(cuid())
  name          String
  userId        String
  mapping       Json      // Column mapping configuration
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TelegramUser {
  id            String    @id @default(cuid())
  telegramId    String    @unique
  userId        String    @unique
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
}
